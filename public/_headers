/*
  # Strict Transport Security — force HTTPS for 2 years, include subdomains, preload
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Prevent clickjacking — deny all iframe embedding
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Enable XSS filter in legacy browsers
  X-XSS-Protection: 1; mode=block

  # Control referrer information leakage
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable dangerous browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=(), midi=(), notifications=(), push=(), speaker=(), vibrate=()

  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://aethera-crm-api.aetherahealthcare.workers.dev https://aethera-forms.aetherahealthcare.workers.dev https://*.resend.com https://api.web3forms.com https://cloudflareinsights.com; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content;

  # Prevent cross-origin information leaks
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

  # Remove server fingerprinting
  X-Powered-By:
  Server:

  # Cache control for HTML pages — always revalidate
  Cache-Control: no-cache, must-revalidate

/brand/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/images/*
  Cache-Control: public, max-age=86400
  Cross-Origin-Resource-Policy: cross-origin

/*.js
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/*.css
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
