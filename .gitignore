# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude settings
.claude/

# Cloudflare deploy token (never commit)
.cf-deploy-token

# --- AETHERA-PROTECT: never publish these to the public repo ---
# Sensitive business data / internal docs that ended up in the website folder
Aethera_*.pdf
Aethera_*.docx
Aethera_*.xlsx
Aethera_*.html
AETHERA_FLEET.md
CONTAINER_RUNTIME.md
SAFE_FAIL.md
.buildexclude
deploy-now.bat
rebuild-website.bat
# Unrelated sub-projects that shouldn't live in the website repo
/aethera-admin/
/aethera-worker/
# Cross-project CI that would fire on push from the wrong repo
/.github/workflows/deploy-production.yml
/.github/workflows/deploy-staging.yml
